# Telegram Bot Configuration

# Get from @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram Numeric ID (get from @userinfobot)
ADMIN_ID=123456789

# Required channel for verification (use @username or -100 ID)
REQUIRED_CHANNEL=@yourchannel

# Required group for verification (use @username or -100 ID)
REQUIRED_GROUP=@yourgroup

# External links for verification
YOUTUBE_LINK=https://youtube.com/@yourchannel
WHATSAPP_LINK=https://whatsapp.com/channel/yourchannel

# Admin contact info shown to users for recharge
ADMIN_WHATSAPP=+923001234567
ADMIN_TELEGRAM=@yourusername
